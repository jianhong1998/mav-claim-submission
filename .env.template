##################################################
############ Environment Config ##################
##################################################
NODE_ENV=local

##################################################
############ Database related ####################
##################################################
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=Password1234
DATABASE_DB=project_db


##################################################
############ Frontend Environment ################
##################################################
# Frontend app port
FRONTEND_PORT=3000
# Backend API URL accessible from browser and frontend server side
FRONTEND_BACKEND_BASE_URL=http://localhost:3001

##################################################
############ Backend Environment  ################
##################################################
BACKEND_PORT=3001
BACKEND_BUILD_MODE=swc
BACKEND_CLIENT_HOST=http://localhost:3000
BACKEND_COOKIE_SECRET=something_secret
BACKEND_COOKIE_DOMAIN_NAME=localhost
# Token encryption for OAuth tokens storage
# Generate a strong random key for production
BACKEND_TOKEN_ENCRYPTION_KEY=dev_encryption_key_32_characters_minimum_length_required_for_aes256
# JWT secret for session tokens
BACKEND_JWT_SECRET=change_this_to_a_strong_jwt_secret_in_production

# Google OAuth Configuration
# Obtain these from Google Cloud Console (https://console.cloud.google.com)
# 1. Create a new project or select existing project
# 2. Enable Google+ API, Gmail API, and Drive API
# 3. Create OAuth 2.0 credentials (Web application)
# 4. Add authorized redirect URIs: http://localhost:3001/auth/google/callback
BACKEND_GOOGLE_CLIENT_ID=your_google_client_id_here
BACKEND_GOOGLE_CLIENT_SECRET=your_google_client_secret_here
BACKEND_GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# Google Drive API Configuration
# Optional API key for additional quota (can be left empty for OAuth-only access)
BACKEND_GOOGLE_DRIVE_API_KEY=your_google_drive_api_key_here_optional
# Drive API scope - limits access to files created by the application
BACKEND_GOOGLE_DRIVE_SCOPE=https://www.googleapis.com/auth/drive.file

# Email Configuration for Claim Submissions
# Email recipient(s) for automated claim submission emails
# REQUIRED: Must be valid email address(es) - system will fail to start if not configured
# Single recipient example: admin@mavericks-consulting.com
# Multiple recipients example: admin@mavericks-consulting.com,hr@mavericks-consulting.com,finance@mavericks-consulting.com
# Validation: Must be proper email format, comma-separated for multiple addresses
# Note: Spaces around commas are automatically trimmed during parsing
BACKEND_EMAIL_RECIPIENT=payroll@mavericks-consulting.com,your_mavericks_email@mavericks-consulting.com



##################################################
############ Backend feature flags ###############
##################################################
# SECURITY WARNING: ENABLE_API_TEST_MODE exposes internal test endpoints
# Only enable in development/test environments - NEVER in production
# Enables POST/DELETE /internal/test-data endpoints for test user management
ENABLE_API_TEST_MODE=false