{
  "mcpServers": {
    "spec-workflow": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "@pimzino/spec-workflow-mcp@latest",
        "./",
        "--AutoStartDashboard",
        "--port",
        "9000"
      ],
      "env": {}
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": ["@playwright/mcp@latest"],
      "env": {}
    },
    "atlassian": {
      "type": "stdio",
      "command": "docker",
      "args": [
        "run",
        "--rm",
        "-i",
        "--env-file",
        "/Users/leejianhong/.claude/mcp-server-configs/atlassian/.env",
        "ghcr.io/sooperset/mcp-atlassian:latest"
      ],
      "env": {}
    }
  }
}
