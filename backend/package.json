{
  "name": "backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write .",
    "dev": "nodemon --watch src --watch ../packages/types --ext ts --exec ts-node -r dotenv/config -r tsconfig-paths/register src/main.ts",
    "start": "node dist/backend/src/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typeorm": "DOTENV_CONFIG_PATH=../.env node -r dotenv/config ./node_modules/typeorm/cli.js -d dist/backend/config/data-source.js",
    "typeorm-extension": "DOTENV_CONFIG_PATH=../.env node -r dotenv/config ./node_modules/typeorm-extension/bin/cli.cjs -d dist/backend/config/data-source.js",
    "migration:run": "pnpm run typeorm migration:run",
    "seed:create": "npx typeorm-extension seed:create -n src/db/seeders/$npm_config_name",
    "seed:run": "npm run typeorm-extension -- seed:run"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.14",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.14",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.14",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "@project/types": "workspace:*",
    "@types/express-session": "^1.18.2",
    "@types/jsonwebtoken": "^9.0.10",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "cookie-parser": "^1.4.7",
    "crypto-js": "^4.2.0",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^17.3.1",
    "express-session": "^1.19.0",
    "google-auth-library": "^10.5.0",
    "googleapis": "^159.0.0",
    "jsonwebtoken": "^9.0.3",
    "nodemon": "^3.1.13",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.18.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.28",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.14",
    "@swc/cli": "^0.8.0",
    "@swc/core": "^1.15.11",
    "@types/cookie-parser": "^1.4.10",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.11",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/supertest": "^6.0.3",
    "@vitest/ui": "^3.2.4",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^16.5.0",
    "prettier": "^3.8.1",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typeorm-extension": "^3.8.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "unplugin-swc": "^1.5.9",
    "vitest": "^3.2.4"
  }
}
